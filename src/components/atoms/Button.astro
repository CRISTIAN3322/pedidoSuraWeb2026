---
// Componente atomico Button - El atomo mas basico y reutilizable
// Props esperadas:
// - variant: 'primary' | 'secondary' | 'danger' | 'blocked' | 'success'
// - size: 'sm' | 'md' | 'lg'
// - disabled: boolean
// - loading: boolean
// - type: 'button' | 'submit' | 'reset'
// - onclick: function
// - children: contenido del boton

const {
  variant = "primary",
  size = "md",
  disabled = false,
  loading = false,
  type = "button",
  onclick = null,
} = Astro.props;
---

<button
  type={type}
  disabled={disabled || loading}
  onclick={onclick}
  class={`atom-button atom-button--${variant} atom-button--${size} ${loading ? "atom-button--loading" : ""}`}
  aria-disabled={disabled || loading}
>
  {loading && <span class="atom-button__spinner" aria-hidden="true" />}
  <slot />
</button>

<style>
  .atom-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: inherit;
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    border: none;
    border-radius: var(--border-radius-lg);
    cursor: pointer;
    transition: var(--transition-all);
    position: relative;
    outline: none;
  }

  /* Variantes */
  .atom-button--primary {
    background-color: var(--color-primary);
    color: var(--color-text-inverse);
  }

  .atom-button--primary:hover:not(:disabled):not(.atom-button--loading) {
    background-color: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-primary-sm);
  }

  .atom-button--secondary {
    background-color: var(--color-neutral);
    color: var(--color-text-inverse);
  }

  .atom-button--secondary:hover:not(:disabled):not(.atom-button--loading) {
    background-color: var(--color-neutral-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(108, 117, 125, 0.3);
  }

  .atom-button--danger {
    background-color: var(--color-danger);
    color: var(--color-text-inverse);
  }

  .atom-button--danger:hover:not(:disabled):not(.atom-button--loading) {
    background-color: #c82333;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(254, 94, 65, 0.3);
  }

  .atom-button--blocked {
    background-color: var(--color-danger);
    color: var(--color-text-inverse);
    cursor: not-allowed;
  }

  .atom-button--blocked:hover {
    background-color: var(--color-danger);
    transform: none;
    box-shadow: none;
  }

  .atom-button--success {
    background-color: var(--color-success);
    color: var(--color-text-inverse);
  }

  .atom-button--success:hover:not(:disabled):not(.atom-button--loading) {
    background-color: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-primary-sm);
  }

  /* Tamanos */
  .atom-button--sm {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-sm);
    min-height: 36px;
  }

  .atom-button--md {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--font-size-base);
    min-height: 44px;
  }

  .atom-button--lg {
    padding: var(--space-md) var(--space-xl);
    font-size: var(--font-size-lg);
    min-height: 52px;
  }

  /* Estados */
  .atom-button:disabled,
  .atom-button--loading {
    opacity: var(--state-disabled-opacity);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .atom-button:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Spinner de carga */
  .atom-button__spinner {
    width: 1rem;
    height: 1rem;
    border: var(--border-width-base) solid transparent;
    border-top: var(--border-width-base) solid currentColor;
    border-radius: var(--border-radius-full);
    animation: atom-button-spin 1s linear infinite;
  }

  @keyframes atom-button-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .atom-button--lg {
      padding: var(--space-sm) var(--space-lg);
      font-size: var(--font-size-base);
    }

    .atom-button--md {
      padding: var(--space-sm) var(--space-md);
      font-size: var(--font-size-sm);
    }
  }
</style>
