---
// Componente atomico StatusBadge - Para mostrar estados con colores
// Props esperadas:
// - status: 'success' | 'warning' | 'danger' | 'info' | 'blocked'
// - size: 'sm' | 'md' | 'lg'
// - children: contenido del badge

const { status = "info", size = "md" } = Astro.props;
---

<span
  class={`atom-status-badge atom-status-badge--${status} atom-status-badge--${size}`}
>
  <slot />
</span>

<style>
  .atom-status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--border-radius-full);
    text-align: center;
  }

  /* Estados */
  .atom-status-badge--success {
    background-color: var(--badge-success-bg);
    color: var(--badge-success-text);
  }

  .atom-status-badge--warning {
    background-color: var(--badge-warning-bg);
    color: var(--badge-warning-text);
  }

  .atom-status-badge--danger {
    background-color: var(--badge-danger-bg);
    color: var(--badge-danger-text);
  }

  .atom-status-badge--blocked {
    background-color: var(--badge-blocked-bg);
    color: var(--badge-blocked-text);
  }

  .atom-status-badge--info {
    background-color: var(--badge-info-bg);
    color: var(--badge-info-text);
  }

  /* Tamanos */
  .atom-status-badge--sm {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--font-size-xs);
  }

  .atom-status-badge--md {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--font-size-sm);
  }

  .atom-status-badge--lg {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--font-size-base);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .atom-status-badge--lg {
      padding: var(--space-xs) var(--space-md);
      font-size: var(--font-size-sm);
    }

    .atom-status-badge--md {
      padding: var(--space-xs) var(--space-sm);
      font-size: var(--font-size-xs);
    }
  }
</style>
