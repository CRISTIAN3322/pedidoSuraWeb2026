---
// Componente atomico Input - Para campos de texto reutilizables
// Props esperadas:
// - type: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search'
// - placeholder: string
// - value: string
// - disabled: boolean
// - readonly: boolean
// - required: boolean
// - error: string
// - label: string
// - id: string
// - name: string
// - size: 'sm' | 'md' | 'lg'

const {
  type = "text",
  placeholder = "",
  value = "",
  disabled = false,
  readonly = false,
  required = false,
  error = "",
  label = "",
  id = "",
  name = "",
  size = "md",
} = Astro.props;
---

<div class="atom-input-wrapper">
  {
    label && (
      <label for={id} class="atom-input__label">
        {label}
        {required && (
          <span class="atom-input__required" aria-label="Campo requerido">
            *
          </span>
        )}
      </label>
    )
  }

  <input
    type={type}
    placeholder={placeholder}
    value={value}
    disabled={disabled}
    readonly={readonly}
    required={required}
    id={id}
    name={name}
    class={`atom-input atom-input--${size} ${error ? "atom-input--error" : ""}`}
    aria-invalid={error ? "true" : "false"}
    aria-describedby={error ? `${id}-error` : undefined}
  />

  {
    error && (
      <div id={`${id}-error`} class="atom-input__error" role="alert">
        {error}
      </div>
    )
  }
</div>

<style>
  .atom-input-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .atom-input__label {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .atom-input__required {
    color: var(--color-danger);
    font-weight: var(--font-weight-bold);
  }

  .atom-input {
    width: 100%;
    font-family: inherit;
    border: var(--border-width-base) solid var(--color-border-default);
    border-radius: var(--border-radius-lg);
    transition: var(--transition-all);
    box-sizing: border-box;
    outline: none;
  }

  .atom-input:focus {
    border-color: var(--color-border-focus);
    box-shadow: 0 0 0 3px rgba(0, 168, 120, 0.1);
  }

  .atom-input--error {
    border-color: var(--color-border-error);
  }

  .atom-input--error:focus {
    border-color: var(--color-border-error);
    box-shadow: 0 0 0 3px rgba(254, 94, 65, 0.1);
  }

  /* Tamanos */
  .atom-input--sm {
    padding: var(--space-sm);
    font-size: var(--font-size-sm);
  }

  .atom-input--md {
    padding: var(--space-sm);
    font-size: var(--font-size-base);
  }

  .atom-input--lg {
    padding: var(--space-md);
    font-size: var(--font-size-lg);
  }

  /* Estados */
  .atom-input:disabled {
    background-color: var(--color-surface-secondary);
    color: var(--color-text-disabled);
    cursor: not-allowed;
  }

  .atom-input:readonly {
    background-color: var(--color-surface-secondary);
    color: var(--color-text-secondary);
    cursor: default;
  }

  .atom-input__error {
    color: var(--color-danger);
    font-size: var(--font-size-xs);
    margin-top: var(--space-xs);
  }

  /* Placeholder styles */
  .atom-input::placeholder {
    color: var(--color-placeholder);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .atom-input--lg {
      padding: var(--space-sm);
      font-size: var(--font-size-base);
    }

    .atom-input--md {
      padding: var(--space-sm);
      font-size: var(--font-size-sm);
    }
  }
</style>
