---
// Componente de bloqueo horario
// Bloquea la aplicación desde blockStartHour hasta startHour del día siguiente
import { APP_CONFIG } from '../../config/app.config';

const ahora = new Date();
const horaActual = ahora.getHours();

// Configuración de bloqueo desde app.config
const horaInicioBloqueo = APP_CONFIG.schedule.blockStartHour; // 23 (11PM)
const horaFinBloqueo = APP_CONFIG.schedule.startHour;         // 5 (5AM)

// Verificar si estamos en horario de bloqueo (desde 23:00 hasta 5:00)
const estaBloqueado = horaActual >= horaInicioBloqueo || horaActual < horaFinBloqueo;

// Calcular tiempo restante hasta el próximo horario disponible
let tiempoRestante = "";
if (estaBloqueado) {
    const ahoraMs = ahora.getTime();
    const proximoDisponible = new Date(ahora);
    
    if (horaActual >= horaInicioBloqueo) {
        // Después de las 23:00, esperar hasta las 5:00 del día siguiente
        proximoDisponible.setDate(proximoDisponible.getDate() + 1);
        proximoDisponible.setHours(horaFinBloqueo, 0, 0, 0);
    } else {
        // Antes de las 5:00, esperar hasta las 5:00 del mismo día
        proximoDisponible.setHours(horaFinBloqueo, 0, 0, 0);
    }
    
    const diferencia = proximoDisponible.getTime() - ahoraMs;
    const horas = Math.floor(diferencia / (1000 * 60 * 60));
    const minutos = Math.floor((diferencia % (1000 * 60 * 60)) / (1000 * 60));
    tiempoRestante = `${horas}h ${minutos}m`;
}
---

{estaBloqueado && (
    <div class="bloqueo-overlay" id="bloqueo-overlay">
        <div class="bloqueo-container">
            <div class="bloqueo-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <h2 class="bloqueo-title">Fuera de Horario de Atención</h2>
            <p class="bloqueo-subtitle">El sistema está temporalmente cerrado.</p>
            
            <div class="bloqueo-horario">
                <div class="horario-item">
                    <span class="horario-label">Horario de atención:</span>
                    <span class="horario-value">5:00 AM - 6:00 PM</span>
                </div>
                <div class="horario-item">
                    <span class="horario-label">Tiempo restante:</span>
                    <span class="horario-value tiempo-restante">{tiempoRestante}</span>
                </div>
            </div>
            
            <div class="bloqueo-info">
                <p>Por favor, vuelve a intentar durante el horario de atención.</p>
                <p>Gracias por tu comprensión.</p>
            </div>
        </div>
    </div>
)}

<style>
    .bloqueo-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--gradient-primary-dark);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: calc(var(--z-index-modal) + 10);
        font-family: var(--font-family-primary);
        padding: var(--space-md);
    }

    .bloqueo-container {
        background: var(--color-surface);
        padding: var(--space-2xl) var(--space-xl);
        border-radius: var(--border-radius-2xl);
        box-shadow: var(--shadow-xl);
        text-align: center;
        max-width: 480px;
        width: 100%;
        animation: bloqueoFadeIn 0.4s ease-out;
    }

    @keyframes bloqueoFadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .bloqueo-icon {
        display: flex;
        justify-content: center;
        margin-bottom: var(--space-lg);
        color: var(--color-primary);
        animation: bloqueoPulse 2s ease-in-out infinite;
    }

    @keyframes bloqueoPulse {
        0%, 100% { 
            transform: scale(1);
            opacity: 1;
        }
        50% { 
            transform: scale(1.1);
            opacity: 0.8;
        }
    }

    .bloqueo-title {
        color: var(--color-text-primary);
        margin-bottom: var(--space-sm);
        font-size: var(--font-size-2xl);
        font-weight: var(--font-weight-bold);
        letter-spacing: -0.02em;
    }

    .bloqueo-subtitle {
        color: var(--color-text-secondary);
        margin-bottom: var(--space-xl);
        font-size: var(--font-size-base);
    }

    .bloqueo-horario {
        background: var(--color-surface-secondary);
        border-radius: var(--border-radius-lg);
        padding: var(--space-lg);
        margin-bottom: var(--space-xl);
        border: var(--border-width-thin) solid var(--color-border-light);
    }

    .horario-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-sm) 0;
    }

    .horario-item:not(:last-child) {
        border-bottom: var(--border-width-thin) solid var(--color-border-default);
    }

    .horario-label {
        color: var(--color-text-secondary);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
    }

    .horario-value {
        color: var(--color-text-primary);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
    }

    .tiempo-restante {
        color: var(--color-primary);
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-bold);
    }

    .bloqueo-info {
        padding-top: var(--space-lg);
        border-top: var(--border-width-thin) solid var(--color-border-default);
    }

    .bloqueo-info p {
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        margin-bottom: var(--space-xs);
    }

    .bloqueo-info p:last-child {
        margin-bottom: 0;
    }

    @media (max-width: 480px) {
        .bloqueo-container {
            padding: var(--space-xl) var(--space-lg);
        }

        .bloqueo-title {
            font-size: var(--font-size-xl);
        }

        .bloqueo-icon svg {
            width: 48px;
            height: 48px;
        }
    }
</style>

<script define:vars={{ horaInicioBloqueo, horaFinBloqueo }}>
    function actualizarTiempoRestante() {
        const ahora = new Date();
        const horaActual = ahora.getHours();
        
        const estaBloqueado = horaActual >= horaInicioBloqueo || horaActual < horaFinBloqueo;
        
        if (estaBloqueado) {
            const proximoDisponible = new Date(ahora);
            
            if (horaActual >= horaInicioBloqueo) {
                proximoDisponible.setDate(proximoDisponible.getDate() + 1);
                proximoDisponible.setHours(horaFinBloqueo, 0, 0, 0);
            } else {
                proximoDisponible.setHours(horaFinBloqueo, 0, 0, 0);
            }
            
            const diferencia = proximoDisponible.getTime() - ahora.getTime();
            const horas = Math.floor(diferencia / (1000 * 60 * 60));
            const minutos = Math.floor((diferencia % (1000 * 60 * 60)) / (1000 * 60));
            const tiempoRestante = `${horas}h ${minutos}m`;
            
            const tiempoElement = document.querySelector('.tiempo-restante');
            if (tiempoElement) {
                tiempoElement.textContent = tiempoRestante;
            }
            
            if (horas === 0 && minutos === 0) {
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            }
        } else {
            const bloqueoOverlay = document.getElementById('bloqueo-overlay');
            if (bloqueoOverlay) {
                bloqueoOverlay.style.display = 'none';
            }
        }
    }

    setInterval(actualizarTiempoRestante, 60000);
    document.addEventListener('DOMContentLoaded', actualizarTiempoRestante);
</script>
