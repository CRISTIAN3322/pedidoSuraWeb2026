---
// Props esperados:
// cartera: array de facturas del cliente
// totalCartera: número
// cupoDisponible: número
// sinCupo: boolean
// mostrar: boolean (opcional, default true)
const { cartera = [], totalCartera = 0, cupoDisponible = 0, sinCupo = false, mostrar = true } = Astro.props;
---
{mostrar && (
  <div class="tabla-cartera">
    <h4>Cartera del Cliente</h4>
    <table>
      <thead>
        <tr>
          <th>Factura</th>
          <th>Fecha</th>
          <th>Vendedor</th>
          <th>Valor</th>
          <th>Días</th>
        </tr>
      </thead>
      <tbody>
        {cartera.length > 0 ? cartera.map((factura: any) => {
          // Manejar el campo vendedor que puede venir como "Vendedor" o "vendedor"
          const vendedorNombre = factura.Vendedor || factura.vendedor || 'N/A';
          // Manejar el valor que puede ser número o string
          const valorNumerico = typeof factura.valor === 'number' 
            ? factura.valor 
            : Number(String(factura.valor).replace(/\./g, '').replace(',', '.')) || 0;
          
          return (
            <tr class={
              Number(factura.dias) >= 30 ? 'dias-mayor-treinta' :
              Number(factura.dias) >= 11 ? 'dias-mayor-diez' :
              Number(factura.dias) >= 1 ? 'dias-mayor-uno' : ''
            }>
              <td>{factura.fac || 'N/A'}</td>
              <td>{factura.fecha || 'N/A'}</td>
              <td>{vendedorNombre}</td>
              <td>${valorNumerico.toLocaleString('es-CO')}</td>
              <td>{factura.dias || 0}</td>
            </tr>
          );
        }) : (
          <tr><td colspan="5">Sin facturas pendientes</td></tr>
        )}
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2"><strong>Total Cartera:</strong></td>
          <td colspan="2"><strong>${totalCartera.toLocaleString('es-CO')}</strong></td>
        </tr>
      </tfoot>
    </table>
    <div class="info-cupo info-cupo--spaced">
      {sinCupo ? (
        <span class="info-cupo__status info-cupo__status--danger">⚠️ SIN CUPO - Cupo: ${cupoDisponible.toLocaleString('es-CO')} | Cartera: ${totalCartera.toLocaleString('es-CO')}</span>
      ) : (
        <span class="info-cupo__status info-cupo__status--success">✅ Con Cupo - Cupo: ${cupoDisponible.toLocaleString('es-CO')} | Cartera: ${totalCartera.toLocaleString('es-CO')}</span>
      )}
    </div>
  </div>
)}

<style>
.tabla-cartera {
    margin: 20px 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
}
.tabla-cartera table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
    min-width: 400px;
}
.tabla-cartera th,
.tabla-cartera td {
    border: 1px solid var(--gray-200);
    padding: 12px 8px;
    text-align: left;
    font-size: 0.9rem;
}
.tabla-cartera th {
    background-color: var(--light-bg);
    font-weight: 600;
    color: var(--primary-color);
    position: sticky;
    top: 0;
    z-index: 10;
}
.tabla-cartera tr:nth-child(even) {
    background-color: var(--color-surface-secondary);
}
.tabla-cartera tr:hover {
    background-color: var(--color-surface-hover);
}
.tabla-cartera tr.dias-mayor-uno {
    background-color: var(--color-warning-light) !important;
}
.tabla-cartera tr.dias-mayor-uno:hover {
    background-color: var(--color-warning-light);
}
.tabla-cartera tr.dias-mayor-diez {
    background-color: var(--color-danger-light) !important;
}
.tabla-cartera tr.dias-mayor-diez:hover {
    background-color: var(--color-danger-light);
}
.tabla-cartera tr.dias-mayor-treinta {
    background-color: var(--color-danger) !important;
    color: var(--color-surface) !important;
}
.tabla-cartera tr.dias-mayor-treinta:hover {
    background-color: var(--color-danger-dark);
    color: var(--color-surface) !important;
}
.tabla-cartera tfoot {
    background-color: var(--color-surface-secondary);
    border-top: 2px solid var(--color-border-default);
}
.tabla-cartera tfoot td {
    font-weight: bold;
    text-align: right;
    padding: 12px 8px;
}
.tabla-cartera tfoot td:first-child {
    text-align: left;
}

.info-cupo {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
}

.info-cupo--spaced {
    margin-top: var(--space-sm);
}

.info-cupo__status {
    display: inline-block;
}

.info-cupo__status--danger {
    color: var(--color-danger);
    font-weight: bold;
}

.info-cupo__status--success {
    color: var(--color-success);
}

/* Responsive para tablas */
@media (max-width: 768px) {
    .tabla-cartera {
        margin: 15px 0;
        border-radius: var(--border-radius);
    }
    
    .tabla-cartera table {
        min-width: 350px;
    }
    
    .tabla-cartera th,
    .tabla-cartera td {
        padding: 8px 6px;
        font-size: 0.85rem;
    }
    
    .tabla-cartera h4 {
        font-size: 1.1rem;
        margin-bottom: 0.75rem;
    }
}

@media (max-width: 480px) {
    .tabla-cartera {
        margin: 10px 0;
    }
    
    .tabla-cartera table {
        min-width: 300px;
    }
    
    .tabla-cartera th,
    .tabla-cartera td {
        padding: 6px 4px;
        font-size: 0.8rem;
    }
    
    .tabla-cartera h4 {
        font-size: 1rem;
        margin-bottom: 0.5rem;
    }
    
    .tabla-cartera tfoot td {
        padding: 8px 4px;
        font-size: 0.85rem;
    }
}
</style> 