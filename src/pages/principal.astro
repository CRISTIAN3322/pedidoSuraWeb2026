---
import ClienteSelector from '../components/organisms/ClienteSelector.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import BloqueoHorario from '../components/organisms/BloqueoHorario.astro';
---

<script>
  // Proteger ruta - verificar si hay sesión activa
  if (typeof window !== 'undefined') {
    const session = sessionStorage.getItem('vendedorSession');
    if (!session) {
      window.location.href = '/login';
    }
  }
</script>
<BaseLayout title="Selección de Cliente - Sura Pedidos Web" description="Selecciona un cliente para realizar un pedido">
    <BloqueoHorario />
    
    <div class="container">
        <header class="page-header">
            <h1>👥 Selección de Cliente</h1>
            <p>Busca y selecciona un cliente para continuar con el pedido</p>
        </header>
        
        <div class="card">
            <ClienteSelector />
        </div>
        
        <!-- <footer class="page-footer">
            <a class="btn btn-secondary" href="/carrito">
                🛒 Ver Carrito
            </a>
            <a class="btn btn-primary" href="/">
                🛍️ Catálogo de Productos
            </a>
        </footer> -->
    </div>
</BaseLayout>

<script>
  (() => {
    const SESSION_KEY = 'vendedorSession';
    const PENDING_KEY = 'pendingUpdatesToast';
    const TOAST_ID = 'update-toast';

    function ensureToast() {
      let el = document.getElementById(TOAST_ID);
      if (el) return el;

      el = document.createElement('div');
      el.id = TOAST_ID;
      el.className = 'update-toast';
      el.innerHTML = `
        <div class="update-toast__title">Cambios detectados</div>
        <div class="update-toast__message" id="update-toast-message"></div>
        <div class="update-toast__actions">
          <button type="button" class="update-toast__btn update-toast__btn--primary" id="update-toast-reload">Recargar</button>
          <button type="button" class="update-toast__btn update-toast__btn--ghost" id="update-toast-close">Cerrar</button>
        </div>
      `;
      document.body.appendChild(el);

      const closeBtn = el.querySelector('#update-toast-close') as HTMLButtonElement | null;
      closeBtn?.addEventListener('click', () => {
        el?.classList.remove('update-toast--visible');
      });

      return el;
    }

    function showToast(message: string) {
      const el = ensureToast();
      const msgEl = el.querySelector('#update-toast-message');
      if (msgEl) msgEl.textContent = message;
      el.classList.add('update-toast--visible');

      const reloadBtn = el.querySelector('#update-toast-reload') as HTMLButtonElement | null;
      if (reloadBtn) {
        reloadBtn.onclick = () => window.location.reload();
      }
    }

    async function maybeShowToastAfterLogin() {
      if (typeof window === 'undefined') return;

      const session = sessionStorage.getItem(SESSION_KEY);
      if (!session) return;

      const pending = sessionStorage.getItem(PENDING_KEY);
      if (!pending) return;

      // Consumir marca para evitar toasts repetidos
      sessionStorage.removeItem(PENDING_KEY);

      // Mensaje solicitado por el usuario (independiente de si el hash cambió).
      // Solo mostramos una vez después del login.
      showToast('Se realizó actualización en Ventas y Productos. Recarga para ver los datos actualizados.');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        maybeShowToastAfterLogin();
      });
    } else {
      maybeShowToastAfterLogin();
    }
  })();
</script>

<style>
    .page-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .page-header p {
        color: var(--color-surface);
        font-size: 1.125rem;
        margin-top: 0.5rem;
        opacity: 0.9;
    }

    .page-footer {
        text-align: center;
        margin-top: 3rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    @media (max-width: 768px) {
        .page-header {
            margin-bottom: 1.5rem;
        }

        .page-header p {
            font-size: 1rem;
        }

        .page-footer {
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            margin-top: 2rem;
        }

        .page-footer .btn {
            width: 100%;
            max-width: 300px;
            min-height: 48px;
        }
    }

    @media (max-width: 480px) {
        .page-header {
            margin-bottom: 1rem;
        }

        .page-header p {
            font-size: 0.9rem;
        }

        .page-footer {
            margin-top: 1.5rem;
        }

        .page-footer .btn {
            min-height: 48px;
            font-size: 0.9rem;
        }
    }
</style>