---
import BaseLayout from '../layouts/BaseLayout.astro';
import BloqueoHorario from '../components/organisms/BloqueoHorario.astro';
---

<script>
  // Proteger ruta - verificar si hay sesión activa
  if (typeof window !== 'undefined') {
    const session = sessionStorage.getItem('vendedorSession');
    if (!session) {
      window.location.href = '/login';
    }
  }
</script>

<BaseLayout title="Ventas - Sura Pedidos Web" description="Consulta tus ventas por proveedor">
  <BloqueoHorario />
  
  <div class="container">
    <header class="header">
      <h1 id="pageTitle">💰 Mis Ventas</h1>
      <p class="subtitle" id="vendedorTitle">Cargando información del vendedor...</p>
      
      <!-- Selector de mes -->
      <div class="mes-selector-container">
        <label for="mesSelector" class="mes-label">Seleccionar Mes:</label>
        <select id="mesSelector" class="mes-selector">
          <option value="">Cargando meses...</option>
        </select>
      </div>
    </header>

    <div class="ventas-container">
      <div id="ventasContent">
        <div class="loading">Cargando datos de ventas...</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Función para formatear números como moneda
  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('es-CO', {
      style: 'currency',
      currency: 'COP',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0
    }).format(amount);
  };

  // Función auxiliar para comparar nombres de vendedores (case-insensitive)
  function compareVendedorNames(name1: string, name2: string): boolean {
    if (!name1 || !name2) return false;
    return name1.trim().toUpperCase() === name2.trim().toUpperCase();
  }

  // Obtener datos del vendedor de la sesión
  function getVendedorNombre() {
    if (typeof window === 'undefined') return null;
    try {
      const session = sessionStorage.getItem('vendedorSession');
      if (!session) return null;
      const sessionData = JSON.parse(session);
      return sessionData.nombre || null;
    } catch {
      return null;
    }
  }

  // Verificar si el usuario es administrador
  function isAdministrador() {
    if (typeof window === 'undefined') return false;
    try {
      const session = sessionStorage.getItem('vendedorSession');
      if (!session) return false;
      const sessionData = JSON.parse(session);
      return (sessionData.rol || '').toLowerCase() === 'administrador';
    } catch {
      return false;
    }
  }

  // Renderizar tabla de carteras para un vendedor
  function renderCarteraTable(carteraVendedor: any) {
    if (!carteraVendedor || !carteraVendedor.facturas || carteraVendedor.facturas.length === 0) {
      return `
        <div class="no-data">
          <p>📋 No se encontraron facturas en cartera para este vendedor.</p>
        </div>
      `;
    }

    // Ordenar facturas por días descendente (las más vencidas primero)
    const facturas = [...carteraVendedor.facturas].sort((a: any, b: any) => {
      const diasA = Number(a.dias) || 0;
      const diasB = Number(b.dias) || 0;
      return diasB - diasA;
    });

    return `
      <div class="cartera-section">
        <h3 class="cartera-title">📋 Cartera del Vendedor</h3>
        <div class="vendedor-stats">
          <div class="stat-card">
            <span class="stat-label">Total Facturas</span>
            <span class="stat-value">${carteraVendedor.totalFacturas}</span>
          </div>
          <div class="stat-card ${carteraVendedor.facturasVencidas > 0 ? 'stat-card--warning' : ''}">
            <span class="stat-label">Facturas Vencidas (≥30 días)</span>
            <span class="stat-value">${carteraVendedor.facturasVencidas}</span>
          </div>
          <div class="stat-card ${carteraVendedor.facturasPorVencer > 0 ? 'stat-card--info' : ''}">
            <span class="stat-label">Por Vencer (11-29 días)</span>
            <span class="stat-value">${carteraVendedor.facturasPorVencer}</span>
          </div>
          <div class="stat-card stat-card--primary">
            <span class="stat-label">Total Cartera</span>
            <span class="stat-value">${formatCurrency(carteraVendedor.totalCartera)}</span>
          </div>
        </div>

        <div class="table-container">
          <table class="ventas-table cartera-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Factura</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th class="text-right">Valor</th>
                <th class="text-center">Días</th>
              </tr>
            </thead>
            <tbody>
              ${facturas.map((factura: any, index: number) => {
                const dias = Number(factura.dias) || 0;
                const rowClass = dias >= 30 ? 'dias-vencida' : dias >= 11 ? 'dias-por-vencer' : dias >= 1 ? 'dias-vigente' : '';
                return `
                  <tr class="${rowClass}">
                    <td class="text-center">${index + 1}</td>
                    <td>${factura.fac || 'N/A'}</td>
                    <td>${factura.cliente || 'N/A'}</td>
                    <td>${factura.fecha || 'N/A'}</td>
                    <td class="text-right amount">${formatCurrency(typeof factura.valor === 'number' ? factura.valor : parseFloat(String(factura.valor).replace(/\./g, '').replace(',', '.')) || 0)}</td>
                    <td class="text-center ${dias >= 30 ? 'dias-danger' : dias >= 11 ? 'dias-warning' : ''}">${dias}</td>
                  </tr>
                `;
              }).join('')}
            </tbody>
            <tfoot>
              <tr>
                <td colspan="4" class="text-right total-label"><strong>Total Cartera:</strong></td>
                <td class="text-right total-amount" colspan="2"><strong>${formatCurrency(carteraVendedor.totalCartera)}</strong></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    `;
  }

  // Función para procesar la nueva estructura y agrupar por mes y grupo
  function procesarVentasPorMesYGrupo(proveedores: any[]): { [mes: string]: { [grupo: string]: number } } {
    const agrupados: { [mes: string]: { [grupo: string]: number } } = {};
    
    proveedores.forEach((prov: any) => {
      const grupo = prov.grupo || 'SIN GRUPO';
      
      // Procesar ventas_por_mes si existe
      if (prov.ventas_por_mes && Array.isArray(prov.ventas_por_mes)) {
        prov.ventas_por_mes.forEach((ventaMes: any) => {
          const mes = (ventaMes.mes || 'SIN MES').toUpperCase();
          const total = ventaMes.total || 0;
          
          if (!agrupados[mes]) {
            agrupados[mes] = {};
          }
          
          // Sumar el total por grupo y mes
          if (!agrupados[mes][grupo]) {
            agrupados[mes][grupo] = 0;
          }
          agrupados[mes][grupo] += total;
        });
      }
    });
    
    return agrupados;
  }

  // Renderizar tabla de ventas para un vendedor agrupada por mes y grupo
  function renderVendedorTable(ventasVendedor: any, vendedorNombre: string, carteraVendedor?: any) {
    if (!ventasVendedor || !ventasVendedor.proveedor || ventasVendedor.proveedor.length === 0) {
      return `
        <div class="no-data">
          <p>📊 No se encontraron datos de ventas para este vendedor.</p>
        </div>
      `;
    }

    // Procesar ventas agrupadas por mes y grupo
    const ventasPorMesYGrupo = procesarVentasPorMesYGrupo(ventasVendedor.proveedor);
    
    // Ordenar meses cronológicamente
    const ordenMeses: { [key: string]: number } = {
      'ENERO': 1, 'FEBRERO': 2, 'MARZO': 3, 'ABRIL': 4,
      'MAYO': 5, 'JUNIO': 6, 'JULIO': 7, 'AGOSTO': 8,
      'SEPTIEMBRE': 9, 'OCTUBRE': 10, 'NOVIEMBRE': 11, 'DICIEMBRE': 12
    };
    
    const mesesOrdenados = Object.keys(ventasPorMesYGrupo).sort((a, b) => 
      (ordenMeses[a] || 99) - (ordenMeses[b] || 99)
    );

    // Calcular total general de todos los meses y grupos
    let totalGeneral = 0;
    const gruposUnicos = new Set<string>();
    
    mesesOrdenados.forEach((mes) => {
      Object.keys(ventasPorMesYGrupo[mes]).forEach((grupo) => {
        gruposUnicos.add(grupo);
        totalGeneral += ventasPorMesYGrupo[mes][grupo];
      });
    });

    const carteraHTML = carteraVendedor ? renderCarteraTable(carteraVendedor) : '';

    // Generar HTML para cada mes
    const mesesHTML = mesesOrdenados.map((mes) => {
      const gruposDelMes = ventasPorMesYGrupo[mes];
      
      // Convertir objeto a array y ordenar por total descendente
      const gruposArray = Object.keys(gruposDelMes).map((grupo) => ({
        grupo,
        total: gruposDelMes[grupo]
      })).sort((a, b) => b.total - a.total);
      
      const totalMes = gruposArray.reduce((sum, item) => sum + item.total, 0);
      
      return `
        <div class="mes-section">
          <h3 class="mes-title">📅 ${mes}</h3>
          <div class="mes-stats">
            <div class="stat-card stat-card--mes">
              <span class="stat-label">Grupos en ${mes}</span>
              <span class="stat-value">${gruposArray.length}</span>
            </div>
            <div class="stat-card stat-card--mes stat-card--primary">
              <span class="stat-label">Total ${mes}</span>
              <span class="stat-value">${formatCurrency(totalMes)}</span>
            </div>
          </div>
          
          <div class="table-container">
            <table class="ventas-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Grupo / Línea</th>
                  <th class="text-right">Total Ventas ${mes}</th>
                </tr>
              </thead>
              <tbody>
                ${gruposArray.map((item: any, index: number) => `
                  <tr>
                    <td class="text-center">${index + 1}</td>
                    <td>${item.grupo}</td>
                    <td class="text-right amount">${formatCurrency(item.total)}</td>
                  </tr>
                `).join('')}
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="2" class="text-right total-label"><strong>Total ${mes}:</strong></td>
                  <td class="text-right total-amount"><strong>${formatCurrency(totalMes)}</strong></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      `;
    }).join('');

    return `
      <div class="vendedor-stats">
        <div class="stat-card">
          <span class="stat-label">Total Grupos</span>
          <span class="stat-value">${gruposUnicos.size}</span>
        </div>
        <div class="stat-card stat-card--primary">
          <span class="stat-label">Total General</span>
          <span class="stat-value">${formatCurrency(totalGeneral)}</span>
        </div>
      </div>

      ${mesesHTML}
      
      ${carteraHTML}
    `;
  }

  // Variables globales para almacenar datos cargados
  let ventasDataGlobal: any[] = [];
  let carterasDataGlobal: any[] = [];
  let mesSeleccionado: string = '';

  // Función para obtener meses únicos de los datos de ventas (nueva estructura)
  function obtenerMesesUnicos(ventasData: any[]): string[] {
    const mesesSet = new Set<string>();
    ventasData.forEach((venta: any) => {
      if (venta.proveedor && Array.isArray(venta.proveedor)) {
        venta.proveedor.forEach((prov: any) => {
          // Procesar ventas_por_mes si existe
          if (prov.ventas_por_mes && Array.isArray(prov.ventas_por_mes)) {
            prov.ventas_por_mes.forEach((ventaMes: any) => {
              if (ventaMes.mes) {
                mesesSet.add(ventaMes.mes.toUpperCase());
              }
            });
          }
        });
      }
    });
    
    // Ordenar meses cronológicamente
    const ordenMeses: { [key: string]: number } = {
      'ENERO': 1, 'FEBRERO': 2, 'MARZO': 3, 'ABRIL': 4,
      'MAYO': 5, 'JUNIO': 6, 'JULIO': 7, 'AGOSTO': 8,
      'SEPTIEMBRE': 9, 'OCTUBRE': 10, 'NOVIEMBRE': 11, 'DICIEMBRE': 12
    };
    
    return Array.from(mesesSet).sort((a, b) => (ordenMeses[a] || 99) - (ordenMeses[b] || 99));
  }

  // Función para filtrar ventas por mes (nueva estructura)
  function filtrarVentasPorMes(ventasData: any[], mes: string): any[] {
    if (!mes) return ventasData;
    
    return ventasData.map((venta: any) => {
      const proveedoresFiltrados = venta.proveedor?.map((prov: any) => {
        // Filtrar ventas_por_mes para solo incluir el mes seleccionado
        if (prov.ventas_por_mes && Array.isArray(prov.ventas_por_mes)) {
          const ventasFiltradas = prov.ventas_por_mes.filter((ventaMes: any) => 
            ventaMes.mes && ventaMes.mes.toUpperCase() === mes.toUpperCase()
          );
          
          // Solo incluir el proveedor si tiene ventas en el mes seleccionado
          if (ventasFiltradas.length > 0) {
            return {
              ...prov,
              ventas_por_mes: ventasFiltradas
            };
          }
        }
        return null;
      }).filter((prov: any) => prov !== null) || [];
      
      return {
        ...venta,
        proveedor: proveedoresFiltrados
      };
    }).filter((venta: any) => venta.proveedor && venta.proveedor.length > 0);
  }

  // Función para llenar el selector de meses
  function llenarSelectorMeses(meses: string[]) {
    const mesSelector = document.getElementById('mesSelector') as HTMLSelectElement;
    if (!mesSelector) return;
    
    mesSelector.innerHTML = '';
    
    if (meses.length === 0) {
      mesSelector.innerHTML = '<option value="">No hay meses disponibles</option>';
      return;
    }
    
    // Agregar opción "Todos los meses"
    const optionTodos = document.createElement('option');
    optionTodos.value = '';
    optionTodos.textContent = 'Todos los meses';
    optionTodos.selected = true;
    mesSeleccionado = '';
    mesSelector.appendChild(optionTodos);
    
    // Agregar cada mes
    meses.forEach((mes) => {
      const option = document.createElement('option');
      option.value = mes;
      option.textContent = mes;
      mesSelector.appendChild(option);
    });
    
    // Agregar evento de cambio
    mesSelector.addEventListener('change', (e) => {
      mesSeleccionado = (e.target as HTMLSelectElement).value;
      renderVentasConFiltro();
    });
  }

  // Función para renderizar ventas con el filtro de mes aplicado
  function renderVentasConFiltro() {
    const vendedorNombre = getVendedorNombre();
    const esAdmin = isAdministrador();
    const ventasContent = document.getElementById('ventasContent');
    
    if (!ventasContent || !vendedorNombre) return;
    
    // Si hay mes seleccionado, filtrar; si no, mostrar todos agrupados por mes
    const ventasDataFiltrado = mesSeleccionado 
      ? filtrarVentasPorMes(ventasDataGlobal, mesSeleccionado)
      : ventasDataGlobal;
    
    // Actualizar título con el mes
    const pageTitle = document.getElementById('pageTitle');
    if (pageTitle) {
      if (esAdmin) {
        pageTitle.textContent = mesSeleccionado 
          ? `👑 Ventas ${mesSeleccionado} - Vista Administrador`
          : '👑 Ventas - Vista Administrador';
      } else {
        pageTitle.textContent = mesSeleccionado 
          ? `💰 Mis Ventas ${mesSeleccionado}`
          : '💰 Mis Ventas';
      }
    }
    
    // Si es administrador, mostrar todas las ventas en acordeón
    if (esAdmin) {
      // Filtrar ventas que tienen datos
      const ventasConDatos = ventasDataFiltrado.filter((venta: any) => 
        venta.proveedor && venta.proveedor.length > 0
      );

      if (ventasConDatos.length === 0) {
        ventasContent.innerHTML = `
          <div class="no-data">
            <p>📊 No se encontraron datos de ventas${mesSeleccionado ? ` para el mes de ${mesSeleccionado}` : ''}.</p>
          </div>
        `;
        return;
      }

      // Calcular total general de todos los vendedores (nueva estructura)
      const totalGlobal = ventasConDatos.reduce((sum: number, venta: any) => {
        const totalVendedor = venta.proveedor.reduce((s: number, p: any) => {
          if (p.ventas_por_mes && Array.isArray(p.ventas_por_mes)) {
            return s + p.ventas_por_mes.reduce((sumMes: number, v: any) => sumMes + (v.total || 0), 0);
          }
          return s;
        }, 0);
        return sum + totalVendedor;
      }, 0);

      // Ordenar por total descendente (nueva estructura)
      ventasConDatos.sort((a: any, b: any) => {
        const totalA = a.proveedor.reduce((sum: number, p: any) => {
          if (p.ventas_por_mes && Array.isArray(p.ventas_por_mes)) {
            return sum + p.ventas_por_mes.reduce((sumMes: number, v: any) => sumMes + (v.total || 0), 0);
          }
          return sum;
        }, 0);
        const totalB = b.proveedor.reduce((sum: number, p: any) => {
          if (p.ventas_por_mes && Array.isArray(p.ventas_por_mes)) {
            return sum + p.ventas_por_mes.reduce((sumMes: number, v: any) => sumMes + (v.total || 0), 0);
          }
          return sum;
        }, 0);
        return totalB - totalA;
      });

      const acordeonHTML = `
        <div class="admin-stats">
          <div class="stat-card stat-card--admin">
            <span class="stat-label">Total Vendedores</span>
            <span class="stat-value">${ventasConDatos.length}</span>
          </div>
          <div class="stat-card stat-card--primary stat-card--admin">
            <span class="stat-label">Total Global ${mesSeleccionado}</span>
            <span class="stat-value">${formatCurrency(totalGlobal)}</span>
          </div>
        </div>

        <div class="accordion-container">
          ${ventasConDatos.map((venta: any, index: number) => {
            const totalVendedor = venta.proveedor.reduce((sum: number, p: any) => {
              if (p.ventas_por_mes && Array.isArray(p.ventas_por_mes)) {
                return sum + p.ventas_por_mes.reduce((sumMes: number, v: any) => sumMes + (v.total || 0), 0);
              }
              return sum;
            }, 0);
            const totalProveedores = venta.proveedor.length;
            const accordionId = `accordion-${index}`;
            
            // Buscar cartera del vendedor
            const carteraVendedor = carterasDataGlobal.find((c: any) => 
              compareVendedorNames(c.vendedor, venta.vendedor)
            );
            
            // Agregar badge de cartera si existe
            const carteraBadge = carteraVendedor 
              ? `<span class="badge badge--cartera">Cartera: ${formatCurrency(carteraVendedor.totalCartera)}</span>`
              : '';
            
            return `
              <div class="accordion-item">
                <button class="accordion-header" onclick="toggleAccordion('${accordionId}')" aria-expanded="false">
                  <div class="accordion-header-content">
                    <span class="accordion-title">${venta.vendedor}</span>
                    <div class="accordion-badges">
                      <span class="badge badge--proveedores">${totalProveedores} proveedores</span>
                      <span class="badge badge--total">${formatCurrency(totalVendedor)}</span>
                      ${carteraBadge}
                    </div>
                  </div>
                  <span class="accordion-icon" id="icon-${accordionId}">+</span>
                </button>
                <div class="accordion-content" id="${accordionId}" style="display: none;">
                  ${renderVendedorTable(venta, venta.vendedor, carteraVendedor)}
                </div>
              </div>
            `;
          }).join('')}
        </div>
      `;

      ventasContent.innerHTML = acordeonHTML;
      return;
    }

    // Si es vendedor normal, mostrar solo sus ventas
    const ventasVendedor = ventasDataFiltrado.find((venta: any) => 
      compareVendedorNames(venta.vendedor, vendedorNombre)
    );

    // Buscar cartera del vendedor
    const carteraVendedor = carterasDataGlobal.find((c: any) => 
      compareVendedorNames(c.vendedor, vendedorNombre)
    );

    if (!ventasVendedor || !ventasVendedor.proveedor || ventasVendedor.proveedor.length === 0) {
      // Si no hay ventas pero hay cartera, mostrar solo la cartera
      if (carteraVendedor) {
        ventasContent.innerHTML = `
          <div class="no-data" style="margin-bottom: 2rem;">
            <p>📊 No se encontraron datos de ventas para el mes de ${mesSeleccionado}.</p>
          </div>
          ${renderCarteraTable(carteraVendedor)}
        `;
        return;
      }
      
      ventasContent.innerHTML = `
        <div class="no-data">
          <p>📊 No se encontraron datos de ventas para el mes de ${mesSeleccionado}.</p>
        </div>
      `;
      return;
    }

    // Renderizar tabla normal para vendedor con cartera
    ventasContent.innerHTML = renderVendedorTable(ventasVendedor, vendedorNombre, carteraVendedor);
  }

  // Renderizar las ventas
  async function renderVentas() {
    const vendedorNombre = getVendedorNombre();
    const esAdmin = isAdministrador();
    const ventasContent = document.getElementById('ventasContent');
    const vendedorTitle = document.getElementById('vendedorTitle');

    if (!vendedorNombre) {
      if (ventasContent) {
        ventasContent.innerHTML = '<div class="error">No se pudo obtener la información del vendedor. Por favor, inicia sesión nuevamente.</div>';
      }
      return;
    }

    // Actualizar título
    const pageTitle = document.getElementById('pageTitle');
    if (pageTitle) {
      if (esAdmin) {
        pageTitle.textContent = '👑 Ventas - Vista Administrador';
      } else {
        pageTitle.textContent = '💰 Mis Ventas';
      }
    }

    if (vendedorTitle) {
      if (esAdmin) {
        vendedorTitle.textContent = `Vista general de todas las ventas por vendedor`;
      } else {
        vendedorTitle.textContent = `Vendedor: ${vendedorNombre}`;
      }
    }

    // Cargar datos de ventas desde el API
    let ventasData: any[] = [];
    let carterasData: any[] = [];
    let timeoutId: any = null;
    
    try {
      const controller = new AbortController();
      timeoutId = setTimeout(() => controller.abort(), 10000); // 10 segundos timeout
      
      // Cargar ventas y carteras en paralelo
      const [ventasResponse, carterasResponse] = await Promise.all([
        fetch('/api/ventas.json', {
          signal: controller.signal,
          headers: {
            'Content-Type': 'application/json',
          },
          method: 'GET',
        }),
        fetch('/api/carteras.json', {
          signal: controller.signal,
          headers: {
            'Content-Type': 'application/json',
          },
          method: 'GET',
        })
      ]);
      
      if (timeoutId) {
        clearTimeout(timeoutId);
        timeoutId = null;
      }
      
      if (!ventasResponse.ok) {
        throw new Error(`Error al cargar datos de ventas: ${ventasResponse.status} ${ventasResponse.statusText}`);
      }
      
      const ventasDataJson = await ventasResponse.json();
      if (!Array.isArray(ventasDataJson)) {
        throw new Error('Los datos de ventas no tienen el formato esperado');
      }
      ventasData = ventasDataJson;
      ventasDataGlobal = ventasData; // Guardar en variable global

      // Cargar carteras (puede fallar sin afectar la carga de ventas)
      if (carterasResponse.ok) {
        const carterasDataJson = await carterasResponse.json();
        if (Array.isArray(carterasDataJson)) {
          carterasData = carterasDataJson;
          carterasDataGlobal = carterasData; // Guardar en variable global
        }
      } else {
        console.warn('No se pudieron cargar las carteras, continuando sin ellas');
      }

      // Obtener meses únicos y llenar el selector
      const mesesUnicos = obtenerMesesUnicos(ventasData);
      llenarSelectorMeses(mesesUnicos);
      
    } catch (error: any) {
      if (timeoutId) {
        clearTimeout(timeoutId);
      }
      console.error('Error cargando datos:', error);
      const errorMessage = error.name === 'AbortError' 
        ? 'La carga de datos está tardando demasiado. Por favor, intenta de nuevo.'
        : error.message || 'Error al cargar los datos. Por favor, recarga la página.';
      
      if (ventasContent) {
        ventasContent.innerHTML = `<div class="error">${errorMessage}</div>`;
      }
      return;
    }

    if (!ventasContent) return;
    
    // Renderizar con el filtro de mes aplicado
    renderVentasConFiltro();
  }

  // Función para toggle del acordeón
  (window as any).toggleAccordion = function(accordionId: string) {
    try {
      const content = document.getElementById(accordionId);
      const icon = document.getElementById(`icon-${accordionId}`);
      const button = content?.previousElementSibling as HTMLElement;
      const accordionItem = button?.closest('.accordion-item') as HTMLElement;

      if (!content || !icon || !button || !accordionItem) {
        console.warn('Elementos del acordeón no encontrados:', { accordionId, content, icon, button, accordionItem });
        return;
      }

      const isExpanded = content.style.display !== 'none';
      
      if (isExpanded) {
        content.style.display = 'none';
        icon.textContent = '+';
        accordionItem.classList.remove('accordion-item--active');
        button.setAttribute('aria-expanded', 'false');
      } else {
        content.style.display = 'block';
        icon.textContent = '−';
        accordionItem.classList.add('accordion-item--active');
        button.setAttribute('aria-expanded', 'true');
      }
    } catch (error) {
      console.error('Error en toggleAccordion:', error);
    }
  };

  // Ejecutar cuando se cargue la página
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      renderVentas().catch((error) => {
        console.error('Error al renderizar ventas:', error);
        const ventasContent = document.getElementById('ventasContent');
        if (ventasContent) {
          ventasContent.innerHTML = '<div class="error">Ocurrió un error al cargar la página. Por favor, recarga.</div>';
        }
      });
    });
  } else {
    // El DOM ya está listo
    renderVentas().catch((error) => {
      console.error('Error al renderizar ventas:', error);
      const ventasContent = document.getElementById('ventasContent');
      if (ventasContent) {
        ventasContent.innerHTML = '<div class="error">Ocurrió un error al cargar la página. Por favor, recarga.</div>';
      }
    });
  }
</script>

<script>
  (() => {
    const CHECK_URL = '/api/datos-version.json';
    const POLL_INTERVAL_MS = 20000;
    const SESSION_KEY = 'vendedorSession';
    const TOAST_ID = 'update-toast';

    let lastVersions: any = null;
    let toastShownForHash = { productos: '', ventas: '' };

    function ensureToast() {
      let el = document.getElementById(TOAST_ID);
      if (el) return el;

      el = document.createElement('div');
      el.id = TOAST_ID;
      el.className = 'update-toast';
      el.innerHTML = `
        <div class="update-toast__title">Cambios detectados</div>
        <div class="update-toast__message" id="update-toast-message"></div>
        <div class="update-toast__actions">
          <button type="button" class="update-toast__btn update-toast__btn--primary" id="update-toast-reload">Recargar</button>
          <button type="button" class="update-toast__btn update-toast__btn--ghost" id="update-toast-close">Cerrar</button>
        </div>
      `;
      document.body.appendChild(el);

      const closeBtn = el.querySelector('#update-toast-close') as HTMLButtonElement | null;
      closeBtn?.addEventListener('click', () => {
        el?.classList.remove('update-toast--visible');
      });

      return el;
    }

    function showToast(message: string) {
      const el = ensureToast();
      const msgEl = el.querySelector('#update-toast-message');
      if (msgEl) msgEl.textContent = message;
      el.classList.add('update-toast--visible');

      const reloadBtn = el.querySelector('#update-toast-reload') as HTMLButtonElement | null;
      if (reloadBtn) {
        reloadBtn.onclick = () => window.location.reload();
      }
    }

    async function fetchVersions() {
      const res = await fetch(CHECK_URL, { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      return res.json();
    }

    async function init() {
      const session = sessionStorage.getItem(SESSION_KEY);
      if (!session) return;

      try {
        lastVersions = await fetchVersions();
      } catch {
        return;
      }

      window.setInterval(async () => {
        try {
          const current = await fetchVersions();

          const productosChanged = current?.productos?.hash && current.productos.hash !== lastVersions?.productos?.hash;
          const ventasChanged = current?.ventas?.hash && current.ventas.hash !== lastVersions?.ventas?.hash;

          if (!productosChanged && !ventasChanged) return;

          const newProductosHash = current?.productos?.hash || '';
          const newVentasHash = current?.ventas?.hash || '';
          if (newProductosHash === toastShownForHash.productos && newVentasHash === toastShownForHash.ventas) return;

          toastShownForHash = { productos: newProductosHash, ventas: newVentasHash };
          lastVersions = current;

          let message = '';
          if (productosChanged && ventasChanged) {
            message = 'Se detectaron cambios en Productos y Ventas. Recarga para ver los datos actualizados.';
          } else if (productosChanged) {
            message = 'Se detectaron cambios en Productos. Recarga para ver los datos actualizados.';
          } else {
            message = 'Se detectaron cambios en Ventas. Recarga para ver los datos actualizados.';
          }

          showToast(message);
        } catch {
          // Silenciar errores de polling
        }
      }, POLL_INTERVAL_MS);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

