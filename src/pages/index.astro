---
import ProductosSelector from "../components/organisms/ProductosSelector.astro";
import BloqueoHorario from "../components/organisms/BloqueoHorario.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ClienteSelector from "../components/organisms/ClienteSelector.astro";
---

<script>
  // Proteger ruta - verificar si hay sesión activa
  if (typeof window !== 'undefined') {
    const session = sessionStorage.getItem('vendedorSession');
    if (!session) {
      window.location.href = '/login';
    }
  }
</script>

<BaseLayout title="Catálogo de Productos - Sura Pedidos Web" description="Explora nuestro catálogo completo de productos con precios actualizados">
    <BloqueoHorario />
    
    <div class="container">
        <header class="header">
            <!-- <h1>🛍️ Catálogo de Productos</h1> -->
            <div class="header-info">
                <div class="info-card">
                    <h3>📅 Última Actualización</h3>
                    <p>01 de junio del 2026</p>
                </div>
                <div class="info-card">
                    <h3>📦 Inventario</h3>
                    <p>Actualizado a las 11:30 </p>
                </div>
                <div class="info-card">
                    <h3>💰 Cartera</h3>
                    <p>Actualizado 01 de junio del 2026</p>
                </div>
                <div class="info-card">
                    <h3>📗 Ventas</h3>
                    <p>Actualizado 30 de mayo del 2026</p>
                </div>
            </div>
            <!-- <div class="header-actions">
                <a class="btn btn-secondary" href="/carrito">
                    🛒 Ver Carrito
                </a>
                <a class="btn btn-primary" href="/principal">
                    👤 Seleccionar Cliente
                </a>
            </div> -->
        </header>
        
        <ClienteSelector/>    
    </div>
</BaseLayout>

<script>
  (() => {
    const CHECK_URL = '/api/datos-version.json';
    const POLL_INTERVAL_MS = 20000;
    const SESSION_KEY = 'vendedorSession';
    const TOAST_ID = 'update-toast';

    let lastVersions: any = null;
    let toastShownForHash = { productos: '', ventas: '' };

    function ensureToast() {
      let el = document.getElementById(TOAST_ID);
      if (el) return el;

      el = document.createElement('div');
      el.id = TOAST_ID;
      el.className = 'update-toast';
      el.innerHTML = `
        <div class="update-toast__title">Cambios detectados</div>
        <div class="update-toast__message" id="update-toast-message"></div>
        <div class="update-toast__actions">
          <button type="button" class="update-toast__btn update-toast__btn--primary" id="update-toast-reload">Recargar</button>
          <button type="button" class="update-toast__btn update-toast__btn--ghost" id="update-toast-close">Cerrar</button>
        </div>
      `;
      document.body.appendChild(el);

      const closeBtn = el.querySelector('#update-toast-close') as HTMLButtonElement | null;
      closeBtn?.addEventListener('click', () => {
        el?.classList.remove('update-toast--visible');
      });

      return el;
    }

    function showToast(message: string) {
      const el = ensureToast();
      const msgEl = el.querySelector('#update-toast-message');
      if (msgEl) msgEl.textContent = message;
      el.classList.add('update-toast--visible');

      const reloadBtn = el.querySelector('#update-toast-reload') as HTMLButtonElement | null;
      if (reloadBtn) {
        reloadBtn.onclick = () => window.location.reload();
      }
    }

    async function fetchVersions() {
      const res = await fetch(CHECK_URL, { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      return res.json();
    }

    async function init() {
      const session = sessionStorage.getItem(SESSION_KEY);
      if (!session) return;

      try {
        lastVersions = await fetchVersions();
      } catch {
        return;
      }

      window.setInterval(async () => {
        try {
          const current = await fetchVersions();

          const productosChanged = current?.productos?.hash && current.productos.hash !== lastVersions?.productos?.hash;
          const ventasChanged = current?.ventas?.hash && current.ventas.hash !== lastVersions?.ventas?.hash;

          if (!productosChanged && !ventasChanged) return;

          // Evitar múltiples toasts para el mismo hash
          const newProductosHash = current?.productos?.hash || '';
          const newVentasHash = current?.ventas?.hash || '';
          if (newProductosHash === toastShownForHash.productos && newVentasHash === toastShownForHash.ventas) return;

          toastShownForHash = { productos: newProductosHash, ventas: newVentasHash };
          lastVersions = current;

          let message = '';
          if (productosChanged && ventasChanged) {
            message = 'Se detectaron cambios en Productos y Ventas. Recarga para ver los datos actualizados.';
          } else if (productosChanged) {
            message = 'Se detectaron cambios en Productos. Recarga para ver los datos actualizados.';
          } else {
            message = 'Se detectaron cambios en Ventas. Recarga para ver los datos actualizados.';
          }

          showToast(message);
        } catch {
          // Silenciar errores de polling
        }
      }, POLL_INTERVAL_MS);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
    .header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .header-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin: 2rem 0;
    }

    .info-card {
        background: var(--white);
        padding: 1.5rem;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-md);
        text-align: center;
        transition: var(--transition);
    }

    .info-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .info-card h3 {
        color: var(--primary-color);
        font-size: 1rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .info-card p {
        color: var(--gray-600);
        font-size: 0.875rem;
        margin: 0;
    }

    .header-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
    }

    @media (max-width: 768px) {
        .header {
            margin-bottom: 1.5rem;
        }

        .header-info {
            grid-template-columns: 1fr;
            gap: 0.75rem;
            margin: 1.5rem 0;
        }

        .info-card {
            padding: 1rem;
        }

        .info-card h3 {
            font-size: 0.9rem;
        }

        .info-card p {
            font-size: 0.8rem;
        }

        .header-actions {
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        .header-actions .btn {
            width: 100%;
            max-width: 300px;
            min-height: 48px;
        }
    }

    @media (max-width: 480px) {
        .header {
            margin-bottom: 1rem;
        }

        .header-info {
            margin: 1rem 0;
        }

        .info-card {
            padding: 0.75rem;
        }

        .info-card h3 {
            font-size: 0.85rem;
        }

        .info-card p {
            font-size: 0.75rem;
        }

        .header-actions .btn {
            min-height: 48px;
            font-size: 0.9rem;
        }
    }
</style>